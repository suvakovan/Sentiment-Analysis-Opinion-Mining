{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Phase 3: Model Training\n",
    "\n",
    "In this notebook, we will load our pre-extracted features and train three different models:\n",
    "1. **Naive Bayes (Baseline)** - Fast, works well with TF-IDF\n",
    "2. **Logistic Regression** - Linear model, often highly effective for text classification\n",
    "3. **LSTM (Deep Learning)** - Sequential model capable of capturing context and long-range dependencies"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import numpy as np\n",
    "import scipy.sparse\n",
    "import matplotlib.pyplot as plt\n",
    "import time\n",
    "import sys\n",
    "import os\n",
    "\n",
    "sys.path.append(os.path.abspath('..'))\n",
    "from src.models import NaiveBayesModel, LogisticRegressionModel, LSTMModel"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Load Data\n",
    "We load the matrices created in Notebook 03."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "try:\n",
    "    # Labels\n",
    "    y_train = np.load('../data/y_train.npy')\n",
    "    y_val = np.load('../data/y_val.npy')\n",
    "    y_test = np.load('../data/y_test.npy')\n",
    "    \n",
    "    # TF-IDF (for NB & LR)\n",
    "    X_train_tfidf = scipy.sparse.load_npz('../data/X_train_tfidf.npz')\n",
    "    X_val_tfidf = scipy.sparse.load_npz('../data/X_val_tfidf.npz')\n",
    "    X_test_tfidf = scipy.sparse.load_npz('../data/X_test_tfidf.npz')\n",
    "    \n",
    "    # Sequences (for LSTM)\n",
    "    X_train_seq = np.load('../data/X_train_seq.npy')\n",
    "    X_val_seq = np.load('../data/X_val_seq.npy')\n",
    "    X_test_seq = np.load('../data/X_test_seq.npy')\n",
    "    \n",
    "    print(\"Data loaded successfully.\")\n",
    "except Exception as e:\n",
    "    print(f\"Error loading data: {e}\")\n",
    "    print(\"Please ensure Phase 2 notebooks were executed properly.\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Train Naive Bayes Model"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "nb_model = NaiveBayesModel()\n",
    "\n",
    "start_time = time.time()\n",
    "nb_model.train(X_train_tfidf, y_train)\n",
    "nb_time = time.time() - start_time\n",
    "\n",
    "print(f\"Naive Bayes trained in {nb_time:.2f} seconds.\")\n",
    "nb_model.save('../models/naive_bayes.pkl')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Train Logistic Regression Model"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "lr_model = LogisticRegressionModel()\n",
    "\n",
    "start_time = time.time()\n",
    "lr_model.train(X_train_tfidf, y_train)\n",
    "lr_time = time.time() - start_time\n",
    "\n",
    "print(f\"Logistic Regression trained in {lr_time:.2f} seconds.\")\n",
    "lr_model.save('../models/logistic_regression.pkl')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Train LSTM Model\n",
    "This deep learning model will take significantly longer to train than traditional ML models."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "lstm_model = LSTMModel(vocab_size=5000, embedding_dim=100, max_length=100)\n",
    "\n",
    "start_time = time.time()\n",
    "history = lstm_model.train(\n",
    "    X_train_seq, y_train,\n",
    "    X_val_seq, y_val,\n",
    "    epochs=10,\n",
    "    batch_size=64,\n",
    "    model_path='../models/lstm_model.keras'\n",
    ")\n",
    "lstm_time = time.time() - start_time\n",
    "\n",
    "print(f\"LSTM trained in {lstm_time:.2f} seconds.\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. Plot LSTM Training History\n",
    "Let's visualize the learning curves for the LSTM model."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "if 'history' in locals():\n",
    "    plt.figure(figsize=(12, 4))\n",
    "    \n",
    "    # Plot training & validation accuracy values\n",
    "    plt.subplot(1, 2, 1)\n",
    "    plt.plot(history.history['accuracy'])\n",
    "    plt.plot(history.history['val_accuracy'])\n",
    "    plt.title('Model accuracy')\n",
    "    plt.ylabel('Accuracy')\n",
    "    plt.xlabel('Epoch')\n",
    "    plt.legend(['Train', 'Validation'], loc='upper left')\n",
    "\n",
    "    # Plot training & validation loss values\n",
    "    plt.subplot(1, 2, 2)\n",
    "    plt.plot(history.history['loss'])\n",
    "    plt.plot(history.history['val_loss'])\n",
    "    plt.title('Model loss')\n",
    "    plt.ylabel('Loss')\n",
    "    plt.xlabel('Epoch')\n",
    "    plt.legend(['Train', 'Validation'], loc='upper left')\n",
    "\n",
    "    plt.tight_layout()\n",
    "    plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 6. Generate Predictions for Phase 4\n",
    "We will generate the test set predictions now so we can evaluate them in Phase 4."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "print(\"Generating predictions...\")\n",
    "y_pred_nb = nb_model.predict(X_test_tfidf)\n",
    "y_pred_lr = lr_model.predict(X_test_tfidf)\n",
    "y_pred_lstm = lstm_model.predict(X_test_seq)\n",
    "\n",
    "y_prob_nb = nb_model.predict_proba(X_test_tfidf)\n",
    "y_prob_lr = lr_model.predict_proba(X_test_tfidf)\n",
    "y_prob_lstm = lstm_model.predict_proba(X_test_seq)\n",
    "\n",
    "np.save('../data/y_pred_nb.npy', y_pred_nb)\n",
    "np.save('../data/y_pred_lr.npy', y_pred_lr)\n",
    "np.save('../data/y_pred_lstm.npy', y_pred_lstm)\n",
    "\n",
    "np.save('../data/y_prob_nb.npy', y_prob_nb)\n",
    "np.save('../data/y_prob_lr.npy', y_prob_lr)\n",
    "np.save('../data/y_prob_lstm.npy', y_prob_lstm)\n",
    "\n",
    "print(\"Predictions saved successfully.\")"
   ]
  }
 ],
