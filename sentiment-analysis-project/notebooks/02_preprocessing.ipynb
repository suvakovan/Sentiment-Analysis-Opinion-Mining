 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Phase 2a: Text Preprocessing\n",
    "\n",
    "In this notebook, we will apply our `TextPreprocessor` module to the dataset. We'll clean the text, remove stop words (while retaining words important for sentiment like 'not'), and lemmatize the words."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import sys\n",
    "import os\n",
    "\n",
    "# Add the parent directory to sys.path so we can import from src\n",
    "sys.path.append(os.path.abspath('..'))\n",
    "from src.preprocessing import TextPreprocessor"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Load Data\n",
    "We load the labeled dataset that we created at the end of Phase 1."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "try:\n",
    "    df = pd.read_csv('../data/labeled_reviews.csv')\n",
    "    print(f\"Loaded {len(df)} reviews.\")\n",
    "except FileNotFoundError:\n",
    "    print(\"Error: labeled_reviews.csv not found. Please run the 01_data_exploration.ipynb notebook first to generate it.\")\n",
    "    # Fallback to creating a sample if missing\n",
    "    df = pd.DataFrame({'review_id': [1,2], 'text': [\"Great product!\", \"Terrible.\"], 'sentiment': [1,0]})"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Initialize Preprocessor and Test"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "preprocessor = TextPreprocessor()\n",
    "\n",
    "# Test on a single sample\n",
    "sample_text = \"I really loved this product, but the shipping was NOT very fast!! 5 stars anyway.\"\n",
    "print(f\"Original: {sample_text}\")\n",
    "print(f\"Processed: {preprocessor.preprocess(sample_text)}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Apply to Entire Dataset\n",
    "This might take a minute depending on the size of the dataset."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from tqdm.auto import tqdm\n",
    "tqdm.pandas()\n",
    "\n",
    "print(\"Applying preprocessing...\")\n",
    "df['cleaned_text'] = df['text'].progress_apply(lambda x: preprocessor.preprocess(x))\n",
    "\n",
    "display(df[['text', 'cleaned_text', 'sentiment']].head())"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Drop Empty Reviews\n",
    "Sometimes preprocessing leaves an empty string if the review was only punctuation or stopwords."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "original_len = len(df)\n",
    "df = df[df['cleaned_text'].str.len() > 0]\n",
    "print(f\"Dropped {original_len - len(df)} empty reviews.\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. Save Cleaned Data"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "output_path = '../data/cleaned_reviews.csv'\n",
    "df.to_csv(output_path, index=False)\n",
    "print(f\"Saved cleaned dataset to {output_path}\")"
   ]
  }
 ],
